APP_NAME=lastshot-laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# lastshot と「全く同じ DB」を共有する。ネイティブ PG の unix ソケット(/tmp)へ繋ぐ
# (host がスラッシュ始まりだと libpq は unix ソケットを使う)。DB_DATABASE は worktree
# スロットに追従(run スクリプトが prod 時に上書き)。ロールは OS ユーザー(trust=パスワード空)。
DB_CONNECTION=pgsql
DB_HOST=/tmp
DB_PORT=5432
DB_DATABASE=lastshot
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=disable

# セッションは cookie(サーバ側ストレージ無し)。理由は README / .env 参照。
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
