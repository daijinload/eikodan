#!/usr/bin/env bash
# サンプル pre-push フック（任意・既定では未インストール）。
#
# 方針: 軽量開発のコミットは素通りさせ、push（＝手元を離れる節目）でだけ CSS ゲートを回す。
#       pre-commit は使わない（最終確認と軽量開発をはっきり分ける）。
# monorepo なので、push 範囲に fastweb/ の変更が含まれるときだけ走らせる。
#
# 導入（リポジトリ直下で1回）:
#   ln -sf ../../fastweb/assets/hooks/pre-push .git/hooks/pre-push
# 解除: rm .git/hooks/pre-push
set -euo pipefail
repo_root="$(git rev-parse --show-toplevel)"

changed=0
# git は push する各 ref を「<local_ref> <local_sha> <remote_ref> <remote_sha>」で stdin に渡す。
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [[ "$local_sha" =~ ^0+$ ]] && continue          # ブランチ削除は対象外
  if [[ "$remote_sha" =~ ^0+$ ]]; then
    base="$(git merge-base "$local_sha" origin/main 2>/dev/null || true)"   # 新規ブランチ
  else
    base="$remote_sha"
  fi
  if [[ -z "$base" ]]; then
    changed=1                                       # 基準不明なら安全側で実行
  elif git diff --name-only "$base..$local_sha" -- fastweb/ | grep -q .; then
    changed=1
  fi
done

[[ "$changed" -eq 0 ]] && exit 0
echo "[pre-push] fastweb changed → CSS gate (assets/check-css.sh)"
bash "$repo_root/fastweb/assets/check-css.sh"
