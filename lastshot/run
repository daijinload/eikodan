#!/usr/bin/env bash
# lastshot/run — タスクランナー(bash 関数 + ディスパッチャ)
#
# なぜ bash か: Make 代替を比較した結論(task-runners/)。just/Task 等は「もう一つ
#   ツールを入れる」。bash だけで完結し、fail-fast(set -euo pipefail)と依存の重複
#   排除(once)で弱点を潰せる = 追加インストール不要で一番シンプルに正しく動く。
#
#   ./run dev           # 実行コマンドを + 付きで表示してから実行(既定ON)
#   ./run -q dev        # -q / Q=1 でコマンド表示を抑止(結果だけ)
#   ./run               # 引数なし → help(一覧)
set -euo pipefail

# postgresql@17 は keg-only(PATH非追加)なので絶対パスで叩く。接続は unix ソケット
# (/tmp)= pg-bench の結論「VMを挟まない・最速」。db クレートの既定接続先と揃える。
PGBIN=/opt/homebrew/opt/postgresql@17/bin
PG_HOST=/tmp

# --- worktree ごとにポート/DB/composeプロジェクトを自動で分ける ----------------------
# 同一マシンで dan1〜dan4 を並列起動してもぶつからないよう、worktree のディレクトリ名から
# スロットを決める(lastshot は常に worktree 直下なので親フォルダ名 = dan2 / eikodan …)。
# DB は 1つのネイティブPostgres を共有(unixソケット・ポート同じ)し、中の database 名だけ分ける。
#   eikodan(本流) → PORT=3000 / DB=lastshot
#   dan2          → PORT=3002 / DB=lastshot_dan2
# dev も compose も同じ機構で動かす(PORT=待受/公開ポート, PGDATABASE=DB名, プロジェクト名)。
# 各値は外から渡せば優先(例: PORT=3009 ./run dev)。
_wt=$(basename "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)")                  # 例: dan2 / eikodan
_slot=$(printf '%s' "$_wt" | grep -oE '[0-9]+$' || true)                            # 末尾数字 → 1,2,… 無ければ空
PG_DB=${PG_DB:-lastshot${_slot:+_dan$_slot}}                                        # 無し→lastshot / dan2→lastshot_dan2
export PGDATABASE="$PG_DB"                                                          # dev: db::connect() が読む / psql・createdb も拾う
export PORT="${PORT:-$((3000 + 10#${_slot:-0}))}"                                   # dev: main.rs / compose: 公開ポート
export BASE_URL="${BASE_URL:-http://127.0.0.1:$PORT}"                               # tests-http の接続先
export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-lastshot${_slot:+_dan$_slot}}" # compose 名衝突回避

# migrations は Flyway で管理する。CLI/JRE はローカルに入れず docker image で実行する
# （compose / CI と同じ版）。tag は docker hub の最新メジャーに追従。
FLYWAY_IMAGE=flyway/flyway:12-alpine

# 依存を「一度だけ」実行するメモ化ヘルパ。連想配列は bash4+ 限定なので、
# 文字列メンバーシップで 3.2/POSIX でも動くようにする(task-runners/bash/run 由来)。
_done=" "
once() {
  {
    _x=$-
    set +x
  } 2>/dev/null
  case "$_done" in *" $1 "*)
    case "$_x" in *x*) set -x ;; esac
    return 0
    ;;
  esac
  _done="$_done$1 "
  case "$_x" in *x*) set -x ;; esac
  "$1"
}

dev() { # 開発サーバ起動(cargo run -p app / DB必須)
  cargo run -p app
}

release() { # 本番相当(stable + Rust既定release=opt-3のみ)でローカル起動。release は常にCLI生成CSSを配信 / DB必須(devと同じnative)
  _run_with_profile --release
}

release-max() { # 本番デプロイ相当(stable + release-max=opt-3+LTO+cgu1)でローカル起動。本番と同じ最大最適化レベル。
  _run_with_profile --profile release-max
}

_run_with_profile() { # internal: stable + 指定 profile で app を起動。release / release-max が共有する本体。
  # release は css_built()=常true(main.rs)。本番CSS(/static/app.css)を minify 生成しておく(無いと404)。
  [ -x assets/tailwindcss ] || {
    echo "Tailwind未取得: ./run css-setup を先に実行"
    return 1
  }
  ./assets/tailwindcss -i assets/input.css -o crates/app/static/app.css --minify
  # stable は Cargo.toml の nightly専用行(cargo-features/codegen-backend)をパース時点で蹴る。
  # 一時的に剥がして必ず元へ戻す。Ctrl-C(INT)/kill(TERM)/端末クローズ(HUP)でも復元するよう全部拾う
  # (mv は冪等: 二重発火しても _bak は1度きりなので 2回目は no-op)。Docker と同じ strip-nightly.sh を使う。
  # _bak は local にしない: set -e 等で関数を抜けて EXIT trap が発火すると関数スコープが消え、
  # set -u 下で $_bak が unbound になり復元 mv ごと飛ぶ(|| true に到達する前に展開エラー)。
  # global なら EXIT 経路でも束縛が残る。trap 側も ${_bak:-} で未割り当てをガードする。
  _bak=$(mktemp)
  cp Cargo.toml "$_bak"
  trap 'mv -f "${_bak:-}" Cargo.toml 2>/dev/null || true' EXIT INT TERM HUP
  bash assets/strip-nightly.sh
  # stable。RUSTFLAGS="" が .cargo/config.toml の -Z threads(nightly)/lld を無効化(Docker と同方針)。
  RUSTUP_TOOLCHAIN=stable RUSTFLAGS="" cargo run "$@" -p app
}

check() { # 型チェック(cargo check --workspace)
  cargo check --workspace
}

watch() { # 保存で再チェック・再起動(bacon)
  bacon
}

db-start() { # ネイティブPostgres起動(ログイン常駐にしない=run)
  brew services run postgresql@17
}

db-stop() { # Postgres停止
  brew services stop postgresql@17
}

# Flyway(docker image)を実行する共通ヘルパ。既定は native dev 用の接続:
#   - native postgres へは host.docker.internal 経由で TCP 接続する
#     （Docker Desktop が host の localhost:5432 へ中継。--add-host は付けない）。
#   - DB名は worktree スロットに応じた $PG_DB（lastshot / lastshot_danN）。
#   - ロールは OS ユーザー(initdb 既定)。trust 認証なのでパスワードは空でよい。
# FLYWAY_URL / FLYWAY_USER / FLYWAY_PASSWORD / FLYWAY_NETWORK を env で上書きできる
# （CI は postgres サービスへ繋ぐので --network=host + localhost を渡す）。
_flyway() {
  local net_arg=""
  if [ -n "${FLYWAY_NETWORK:-}" ]; then net_arg="--network=${FLYWAY_NETWORK}"; fi
  # net_arg は空なら「引数なし」、設定時のみ --network=... の1個。クォートすると空文字が
  # 1引数として docker に渡ってしまうので、意図的に非クォート（SC2086 を無効化）。
  # shellcheck disable=SC2086
  docker run --rm ${net_arg} \
    -v "$PWD/migrations:/flyway/sql:ro" \
    -v "$PWD/flyway.toml:/flyway/conf/flyway.toml:ro" \
    -e FLYWAY_URL="${FLYWAY_URL:-jdbc:postgresql://host.docker.internal:5432/$PG_DB}" \
    -e FLYWAY_USER="${FLYWAY_USER:-$USER}" \
    -e FLYWAY_PASSWORD="${FLYWAY_PASSWORD:-}" \
    "$FLYWAY_IMAGE" -configFiles=/flyway/conf/flyway.toml -connectRetries=60 "$@"
}

db-migrate() { # Flywayでmigrationsを適用(docker / native DBへ host.docker.internal 経由)
  _flyway migrate
}

db-info() { # 適用状況を表示(flyway info)
  _flyway info
}

db-setup() { # DB作成 + Flyway migrate(冪等。何度流してもよい)
  "$PGBIN/createdb" -h "$PG_HOST" "$PG_DB" 2>/dev/null || true
  db-migrate
}

db-reset() { # DBを作り直す(スキーマもカウント値もまっさらに作り直し)
  "$PGBIN/dropdb" -h "$PG_HOST" --if-exists "$PG_DB"
  db-setup
}

css-setup() { # Tailwind CLI + daisyUI を取得(初回のみ)
  bash assets/setup-css.sh
}

css-check() { # 本番CSSをクリーン生成し semgrep でパージ検査(push前ゲート)
  bash assets/check-css.sh
}

lint-setup() { # lint/fmtツール取得(初回のみ: oxfmtをローカル固定 ほか確認)
  bash lint/setup.sh
}

lint() { # fmt/lint通しゲート(読取専用/push前に手動。詳細 lint/README.md)
  bash lint/check.sh
}

fmt() { # push前の一括整形(書込/lintの対。dev中はcargo fmt -p <crate>で個別に)
  bash lint/fmt.sh
}

test-http() { # 起動済みサーバへHTTPブラックボックステスト(別ワークスペース)
  (cd tests-http && cargo nextest run)
}

browser-setup() { # ブラウザテストの依存取得(初回のみ: npm + Chromium)
  (cd browser && npm install && npx playwright install chromium)
}

browser() { # ブラウザ駆動テスト(Playwright / 要・起動済みサーバ)
  [ -d browser/node_modules ] || {
    echo "依存が未取得: ./run browser-setup を先に実行"
    return 1
  }
  (cd browser && npm test)
}

test() { # まとめてテスト(http +(あれば)browser)
  once test-http
  [ -d browser ] && once browser || true
}

up() { # 結合用に app+pg を compose で起動(同一網/TCP接続)
  docker compose up --build
}

down() { # compose を即停止(SIGKILL / 使い捨て前提)
  docker compose down -t 0
}

# --- CI(.github/workflows/lastshot-ci.yml)をローカルで一気通しする ------------------
# CI と同じ TCP postgres・release バイナリ・test-http→browser の流れを手元で再現する。
# postgres は「使い捨てコンテナ」を worktree ごとのポートで立てる(5432+slot ＝ dan1〜dan4 並列OK・
# ネイティブPGの 5432 とも衝突しない)。compose の postgres には公開ポートが無い(同一網前提・
# worktree 並列のため不変にしている)ので、ここは docker run で host に publish する。
# 破棄は docker rm -f(即SIGKILL ＝ down -t 0 と同じ作法)。
CI_PG_NAME="lastshot-ci-pg${_slot:-0}"
CI_PGPORT="${CI_PGPORT:-$((5432 + 10#${_slot:-0}))}"

build-release() { # release ビルド(CIと同じ cargo build --release -p app)
  cargo build --release -p app
}

ci-db-up() { # 使い捨て postgres(TCP)を起動しヘルスを待つ(要 DATABASE_URL 経路)
  docker rm -f "$CI_PG_NAME" >/dev/null 2>&1 || true
  docker run -d --name "$CI_PG_NAME" \
    -e POSTGRES_USER=lastshot -e POSTGRES_PASSWORD=lastshot -e POSTGRES_DB="$PGDATABASE" \
    -p "${CI_PGPORT}:5432" postgres:17-alpine >/dev/null
  for i in $(seq 1 30); do
    docker exec "$CI_PG_NAME" pg_isready -U lastshot -d "$PGDATABASE" >/dev/null 2>&1 && return 0
    sleep 1
  done
  echo "postgres が起動しませんでした:"
  docker logs "$CI_PG_NAME"
  return 1
}

ci-db-down() { # 使い捨て postgres を即破棄(SIGKILL)
  docker rm -f "$CI_PG_NAME" >/dev/null 2>&1 || true
}

ci-migrate() { # 使い捨てpgへ Flyway で migrations を適用(CIと同じ db-migrate 経路)
  # CI と同様 Flyway(docker)を --network=host で回し、host に publish した使い捨てpgの
  # localhost:CI_PGPORT へ繋ぐ。db-migrate(=_flyway)を FLYWAY_* env で上書きするだけ。
  FLYWAY_NETWORK=host \
    FLYWAY_URL="jdbc:postgresql://localhost:${CI_PGPORT}/${PGDATABASE}" \
    FLYWAY_USER=lastshot FLYWAY_PASSWORD=lastshot \
    db-migrate
}

ci-app-start() { # release バイナリを TCP 接続で起動(ログ/PIDは worktree ごと)
  HOST=127.0.0.1 PORT="$PORT" nohup ./target/release/app \
    >"/tmp/lastshot-ci-app-${_slot:-0}.log" 2>&1 &
  echo $! >"/tmp/lastshot-ci-app-${_slot:-0}.pid"
}

ci-app-wait() { # アプリの起動を待つ(BASE_URL に疎通するまで最大60s)
  for i in $(seq 1 60); do
    curl -sf "$BASE_URL/" >/dev/null && {
      echo "app is up after ${i}s"
      return 0
    }
    sleep 1
  done
  echo "app が起動しませんでした:"
  cat "/tmp/lastshot-ci-app-${_slot:-0}.log"
  return 1
}

ci-app-stop() { # ci-app-start で起動したアプリを停止
  local pf="/tmp/lastshot-ci-app-${_slot:-0}.pid"
  [ -f "$pf" ] && kill "$(cat "$pf")" 2>/dev/null || true
  rm -f "$pf"
}

ci() { # CIをローカルで一気通し(build→CSSゲート→TCP pg→起動→test-http→browser)
  # CI と同じ TCP 接続(db::connect() が DATABASE_URL を優先 ＝ unix ソケットでなく compose 同一網作法)。
  export DATABASE_URL="postgres://lastshot:lastshot@127.0.0.1:${CI_PGPORT}/${PGDATABASE}"
  trap 'ci-app-stop; ci-db-down' EXIT # 成否によらず必ずアプリ停止＋pg破棄
  build-release
  once css-setup
  css-check
  ci-db-up
  ci-migrate
  ci-app-start
  ci-app-wait
  test-http
  once browser-setup
  browser
  echo "CI(local) OK"
}

help() { # タスク一覧
  echo "usage: ./run <task> [args]"
  echo "tasks:"
  grep -E '^[a-z][a-z_-]*\(\) +\{ +#' "$0" |
    sed -E 's/\(\) +\{ +# */\t/' | sort | sed 's/^/  /'
}

# 実行するコマンドを + 付き(展開済み)で表示する(既定ON)。-q または Q=1 で抑止。
_trace=1
[ "${Q:-0}" = 1 ] && _trace=0
[ "${1:-}" = "-q" ] && {
  shift
  _trace=0
}
[ "${1:-help}" = "help" ] && _trace=0 # 一覧(help)はトレースしない
[ "$_trace" = 1 ] && {
  PS4='+ '
  set -x
}

# ディスパッチ: 引数が無ければ help、あれば $1 と同名の関数を実行
"${@:-help}"
